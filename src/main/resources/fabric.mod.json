{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "A mod that adds commands that provide helpful information related to enchantments.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/GetEnchantInfo",
		"sources": "https://github.com/brainage04/GetEnchantInfo"
	},
	"license": "MIT",
	"icon": "assets/getenchantinfo/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"io.github.brainage04.GetEnchantInfo"
		]
	},
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"accessWidener": "getenchantinfo.accesswidener"
}
